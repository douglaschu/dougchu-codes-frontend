---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import constructionManGif from "../assets/old-under-construction-gif.gif";
import { Image } from "astro:assets";
---

<!doctype html>
<head>
     <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
     <Header />
     <main>
          <h1>Portfolio</h1>
          <p>Gaze upon my works, ye mighty, and despair!</p>
          <img
               src="/images/old-under-construction-gif.gif"
               alt="web 1.0 under construction stick figure man gif"
          />
          <p>
               <i>This page is currently under construction. Pardon our dust.</i
               >
          </p>
     </main>
     <Footer />
</body>
